# ============================================================
# XManager — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# --- Base de Datos (requerido) ---
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/xmanager
PGDATABASE=xmanager
PGHOST=localhost
PGPORT=5432
PGUSER=usuario
PGPASSWORD=contraseña

# URL alternativa para desarrollo local (opcional, usa DATABASE_URL si está definido)
DATABASE_URL_DEV=postgresql://postgres:postgres@localhost/telecom

# --- Autenticación (requerido) ---
SESSION_SECRET=cambia-este-valor-por-una-cadena-aleatoria-segura
SECRET_KEY=cambia-este-valor-por-una-cadena-aleatoria-segura

# --- Supabase Storage (requerido para subida de archivos) ---
SUPABASE_URL=https://ktubdwatxqeqmwlwlizz.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key-aqui

# --- Firebase (opcional — requerido si usas Firebase Auth) ---
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_API_KEY=tu-api-key
FIREBASE_APP_ID=tu-app-id

# --- Google OAuth (opcional — requerido si usas login con Google) ---
GOOGLE_CLIENT_ID=tu-google-client-id
GOOGLE_CLIENT_SECRET=tu-google-client-secret

# --- General ---
DEBUG=False
PORT=5000

# Replit (solo en entorno Replit)
# REPLIT_DEPLOYMENT=true
